# Configuration du serveur
PORT=4317
NODE_ENV=development

# CORS — origine autorisée pour le frontend
CORS_ORIGIN=http://localhost:5173

# Chemin de la base de données SQLite
# Par défaut : data/arbitrage.db dans le répertoire backend/
# DB_PATH=/chemin/absolu/vers/arbitrage.db

# Niveau de log : error | warn | info | debug
LOG_LEVEL=info
